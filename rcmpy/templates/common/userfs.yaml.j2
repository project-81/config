---
hooks: [~/workspace/hooks]

projects:
  ctags:
    source: github
    path: universal-ctags

  crosstool-ng:
    source: github
    path: crosstool-ng
    fetch:
      branch: master
      single-branch: true
      depth: 1

  lcov:
    source: github
    path: linux-test-project
{% for repo in git.repos.vkottler %}

  {{repo}}:
    source: github
    path: vkottler
{% endfor %}
{% if env.platform.node in computers.gui %}

  alacritty:
    source: github
    path: alacritty
{% endif %}
{% if env.platform.node in computers.pi %}

  OctoPrint:
    source: github
    path: OctoPrint

  picamera2:
    source: github
    path: raspberrypi
{% endif %}
